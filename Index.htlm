<!DOCTYPE html>
<html lang="es-MX">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Ruta Libre — Carga Pesada MX</title>
<meta name="description" content="Horarios de circulación y rutas de referencia para camiones de carga pesada en México." />

<link rel="manifest" href="manifest.json" />
<meta name="theme-color" content="#141312" />
<link rel="icon" href="data:image/svg+xml;base64," />
<link rel="apple-touch-icon" href="data:image/svg+xml;base64," />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Ruta Libre" />
<meta name="mobile-web-app-capable" content="yes" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #141312; }
  body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
  ::selection { background: #FFC629; color: #141414; }
  .navbtn { transition: color .15s ease, opacity .15s ease; }
  #root { min-height: 100vh; }
  @media (max-width: 720px) {
    .desktop-nav { display: none !important; }
    .mobile-toggle { display: flex !important; }
  }
  @media (min-width: 721px) {
    .mobile-toggle { display: none !important; }
  }
</style>
</head>
<body>
<div id="root"></div>

<script type="text/babel" data-presets="react">
const { useState, useMemo } = React;

/* ============ ICONOS (SVG propios, sin dependencias externas) ============ */
function Icon({ children, size = 18, color = "currentColor", style, ...rest }) {
  return (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke={color}
      strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={style} {...rest}>
      {children}
    </svg>
  );
}
const Truck = (p) => <Icon {...p}><rect x="1" y="6" width="13" height="11" rx="1"/><path d="M14 9h4l3 3v5h-7z"/><circle cx="6" cy="18.5" r="1.8"/><circle cx="17.5" cy="18.5" r="1.8"/></Icon>;
const MapPin = (p) => <Icon {...p}><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="2.6"/></Icon>;
const ClockIcon = (p) => <Icon {...p}><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.2 2"/></Icon>;
const AlertTriangle = (p) => <Icon {...p}><path d="M10.6 3.6 1.9 19a1.7 1.7 0 0 0 1.5 2.5h17.2A1.7 1.7 0 0 0 22.1 19L13.4 3.6a1.7 1.7 0 0 0-2.8 0Z"/><path d="M12 9v4.5"/><path d="M12 17h.01"/></Icon>;
const ChevronRight = (p) => <Icon {...p}><path d="m9 6 6 6-6 6"/></Icon>;
const Menu = (p) => <Icon {...p}><path d="M3 6h18M3 12h18M3 18h18"/></Icon>;
const X = (p) => <Icon {...p}><path d="M18 6 6 18M6 6l12 12"/></Icon>;
const ShieldAlert = (p) => <Icon {...p}><path d="M12 2 4 5v6c0 5 3.4 9 8 11 4.6-2 8-6 8-11V5z"/><path d="M12 8v4.5"/><path d="M12 16h.01"/></Icon>;
const Calendar = (p) => <Icon {...p}><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/></Icon>;
const ExternalLink = (p) => <Icon {...p}><path d="M14 4h6v6"/><path d="M10 14 20 4"/><path d="M19 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h6"/></Icon>;
const CheckCircle2 = (p) => <Icon {...p}><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.3 2.3L16 10"/></Icon>;
const XCircle = (p) => <Icon {...p}><circle cx="12" cy="12" r="9"/><path d="m9 9 6 6M15 9l-6 6"/></Icon>;

const CIUDADES = [
  { id: "cdmx-centro", ciudad: "Ciudad de México", zona: "Centro Histórico (Perímetro A)", peso: "3.8 – 20 toneladas", regla: "Prohibida la circulación y maniobras de carga de 07:00 a 20:00 h, todos los días.", libre: "20:00 h – 07:00 h", excepciones: "Vehículos de emergencia, mudanzas con permiso, servicios funerarios y transporte de residuos peligrosos autorizado.", fuente: "SEMOVI CDMX", nivel: "alta" },
  { id: "cdmx-periferico", ciudad: "Ciudad de México", zona: "Periférico y Circuito Interior (carriles centrales)", peso: "Más de 3.8 toneladas", regla: "Restringido en carriles centrales del Periférico según el Reglamento de Tránsito, Art. 26. Los carriles laterales suelen permitir carga ligera.", libre: "Consulta vialidad específica", excepciones: "Verifica el tramo exacto: la restricción varía entre norte, sur, oriente y poniente.", fuente: "Reglamento de Tránsito CDMX", nivel: "media" },
  { id: "cdmx-hoy-no-circula", ciudad: "Ciudad de México y Zona Metropolitana", zona: "Hoy No Circula (aplica también a carga sin holograma 00/0)", peso: "Todos los pesos, según holograma de verificación", regla: "Rotación diaria por terminación de placa y holograma. Contingencias ambientales añaden restricciones extra (Fase 1 / Fase 2).", libre: "Días y horas fuera de tu rotación asignada", excepciones: "Diésel y gas LP con normas propias; unidades 00 exentas salvo contingencia.", fuente: "SEDEMA / Programa de Verificación Vehicular", nivel: "media" },
  { id: "gdl", ciudad: "Guadalajara (ZMG)", zona: "Centro y Anillo Periférico", peso: "Más de 3.5 toneladas", regla: "Circulación de carga restringida en el primer cuadro en horario diurno; carga y descarga solo en horario nocturno autorizado.", libre: "Horario nocturno (confirmar con Movilidad Jalisco)", excepciones: "Reparto local con permiso municipal.", fuente: "Movilidad Jalisco", nivel: "media" },
  { id: "mty", ciudad: "Monterrey (AMM)", zona: "Centro y vialidades primarias", peso: "Más de 8.5 toneladas", regla: "Restricción en horas pico (07:00–09:30 y 18:00–20:30) sobre ejes viales primarios.", libre: "Fuera de horas pico", excepciones: "Carga urgente con permiso de la Agencia para la Racionalización y Modernización del Transporte Público (AC Transporte).", fuente: "Gobierno de Nuevo León", nivel: "baja" },
  { id: "puebla", ciudad: "Puebla", zona: "Centro Histórico", peso: "Más de 3.5 toneladas", regla: "Prohibida circulación diurna en el Centro Histórico; carga y descarga solo de 22:00 a 06:00 h.", libre: "22:00 h – 06:00 h", excepciones: "Servicios esenciales con permiso.", fuente: "Ayuntamiento de Puebla", nivel: "media" },
];

const CAMINOS_FEDERALES = [
  { tipo: "ET4 / A4 / B4", desc: "Carreteras de altas especificaciones (4 carriles, cuota o libres amplias)", circulacion: "Libre las 24 horas, todos los días", color: "verde" },
  { tipo: "ET2 / A2 / B2 / C / D", desc: "Carreteras de 2 carriles o especificación menor", circulacion: "Diurno 06:00–18:30 h. Nocturno 00:00–06:00 y 18:30–23:59 h, condicionado a usar carro piloto delantero y trasero", color: "amarillo" },
];

const TEMPORADAS = [
  { nombre: "Semana Santa", detalle: "La Dirección General de Autotransporte Federal (DGAF) emite un aviso anual restringiendo carga pesada en fechas de mayor afluencia. Grúas industriales y transporte de maquinaria pesada suelen suspender circulación por completo en los días pico.", accion: "Revisa el aviso oficial de la DGAF/SCT cada año antes de Semana Santa — las fechas exactas cambian." },
  { nombre: "Puentes y días festivos", detalle: "Muchos estados aplican restricciones similares en Navidad, Año Nuevo y puentes largos, sobre todo en accesos a zonas turísticas y metropolitanas.", accion: "Consulta el calendario de la SICT y el gobierno estatal del tramo antes de salir." },
];

const FUENTES_OFICIALES = [
  { nombre: "SICT — Secretaría de Infraestructura, Comunicaciones y Transportes", url: "https://www.gob.mx/sict" },
  { nombre: "SEMOVI Ciudad de México", url: "https://semovi.cdmx.gob.mx" },
  { nombre: "Gaceta Oficial de la Ciudad de México", url: "https://data.consejeria.cdmx.gob.mx/index.php/gaceta" },
  { nombre: "Guardia Nacional — Carreteras (estado de vialidades)", url: "https://www.gob.mx/guardianacional" },
];

const NIVEL_STYLES = {
  alta: { bg: "#3A1216", border: "#C1272D", text: "#FF8A8F", label: "Restricción estricta" },
  media: { bg: "#3A2E0E", border: "#FFC629", text: "#FFD666", label: "Restricción parcial" },
  baja: { bg: "#0F2E22", border: "#0B6E4F", text: "#6FD9AE", label: "Restricción leve" },
};

function Logo() {
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
      <div style={{ width: 40, height: 40, background: "#FFC629", borderRadius: 6, display: "flex", alignItems: "center", justifyContent: "center", transform: "rotate(-2deg)", boxShadow: "2px 2px 0 #141414" }}>
        <Truck size={22} color="#141414" strokeWidth={2.4} />
      </div>
      <div style={{ lineHeight: 1.05 }}>
        <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 19, fontWeight: 700, color: "#F5F3EE", letterSpacing: 0.3 }}>RUTA LIBRE</div>
        <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 10.5, fontWeight: 500, color: "#0B6E4F", letterSpacing: 3 }}>CARGA PESADA MX</div>
      </div>
    </div>
  );
}

function SignalCard({ status }) {
  const good = status.activo;
  return (
    <div style={{ position: "relative", border: `3px solid ${good ? "#0B6E4F" : "#C1272D"}`, borderRadius: 12, padding: "22px 20px", background: good ? "linear-gradient(135deg, #0F2E22 0%, #12241D 100%)" : "linear-gradient(135deg, #3A1216 0%, #241012 100%)", boxShadow: `0 0 0 1px rgba(255,255,255,0.03), 0 8px 24px -8px ${good ? "#0B6E4F55" : "#C1272D55"}` }}>
      <div style={{ position: "absolute", top: 14, right: 16, opacity: 0.5 }}>
        {good ? <CheckCircle2 size={22} color="#6FD9AE" /> : <XCircle size={22} color="#FF8A8F" />}
      </div>
      <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 12, letterSpacing: 2.5, color: good ? "#6FD9AE" : "#FF8A8F", fontWeight: 600 }}>
        {good ? "CIRCULACIÓN PERMITIDA" : "CIRCULACIÓN RESTRINGIDA"}
      </div>
      <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 26, color: "#F5F3EE", fontWeight: 700, marginTop: 6 }}>{status.texto}</div>
      {status.sub && <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 13.5, color: "#B9B6AC", marginTop: 8, lineHeight: 1.5 }}>{status.sub}</div>}
    </div>
  );
}

function CiudadCard({ c, expanded, onToggle }) {
  const style = NIVEL_STYLES[c.nivel];
  return (
    <div onClick={onToggle} style={{ background: "#1B1B1A", border: "1px solid #2C2B27", borderRadius: 10, padding: "16px 18px", cursor: "pointer" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 12 }}>
        <div>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <MapPin size={15} color="#FFC629" />
            <span style={{ fontFamily: "'Oswald', sans-serif", fontSize: 16, fontWeight: 600, color: "#F5F3EE" }}>{c.ciudad}</span>
          </div>
          <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 13, color: "#9C998E", marginTop: 3 }}>{c.zona}</div>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 8, flexShrink: 0 }}>
          <span style={{ fontFamily: "'Inter', sans-serif", fontSize: 10.5, fontWeight: 600, padding: "4px 9px", borderRadius: 20, background: style.bg, color: style.text, border: `1px solid ${style.border}55`, whiteSpace: "nowrap" }}>{style.label}</span>
          <ChevronRight size={18} color="#6B6960" style={{ transform: expanded ? "rotate(90deg)" : "rotate(0deg)", transition: "transform 0.15s ease" }} />
        </div>
      </div>
      {expanded && (
        <div style={{ marginTop: 14, paddingTop: 14, borderTop: "1px dashed #333230" }}>
          <InfoRow label="Peso que aplica" value={c.peso} />
          <InfoRow label="Restricción" value={c.regla} />
          <InfoRow label="Circulación libre" value={c.libre} />
          <InfoRow label="Excepciones" value={c.excepciones} />
          <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 11.5, color: "#6B6960", marginTop: 10 }}>Fuente: {c.fuente}</div>
        </div>
      )}
    </div>
  );
}

function InfoRow({ label, value }) {
  return (
    <div style={{ marginBottom: 9 }}>
      <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 10.5, letterSpacing: 1.5, color: "#0B6E4F", fontWeight: 600 }}>{label.toUpperCase()}</div>
      <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 13.5, color: "#D8D5CB", lineHeight: 1.5, marginTop: 2 }}>{value}</div>
    </div>
  );
}

function SectionTitle({ eyebrow, title }) {
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 11, letterSpacing: 3, color: "#FFC629", fontWeight: 600 }}>{eyebrow}</div>
      <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 22, color: "#F5F3EE", fontWeight: 700, marginTop: 2 }}>{title}</div>
    </div>
  );
}

function DisclaimerBox() {
  return (
    <div style={{ marginTop: 24, background: "#1B1B1A", border: "1px dashed #3A3833", borderRadius: 10, padding: 14, display: "flex", gap: 10 }}>
      <AlertTriangle size={16} color="#6B6960" style={{ flexShrink: 0, marginTop: 2 }} />
      <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 12, color: "#8B8880", lineHeight: 1.6 }}>
        Los horarios y zonas pueden cambiar por decreto o contingencia ambiental. Esta guía resume disposiciones publicadas por las autoridades; confirma siempre en la fuente oficial antes de iniciar tu ruta.
      </div>
    </div>
  );
}

function App() {
  const [tab, setTab] = useState("inicio");
  const [expandedCity, setExpandedCity] = useState("cdmx-centro");
  const [menuOpen, setMenuOpen] = useState(false);

  const now = new Date();
  const hora = now.getHours();
  const centroActivo = !(hora >= 7 && hora < 20);

  const status = useMemo(() => {
    if (centroActivo) {
      return { activo: true, texto: "Centro Histórico CDMX — vía libre", sub: `Son las ${now.toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" })}. El horario libre para carga (3.8–20 t) es de 20:00 a 07:00 h.` };
    }
    const faltan = 20 - hora;
    return { activo: false, texto: "Centro Histórico CDMX — restringido", sub: `Son las ${now.toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" })}. Se libera a las 20:00 h (en ${faltan > 0 ? faltan : faltan + 24} h aprox.).` };
  }, [hora, centroActivo]);

  const TABS = [
    { id: "inicio", label: "Inicio" },
    { id: "ciudades", label: "Ciudades" },
    { id: "carreteras", label: "Carreteras" },
    { id: "temporadas", label: "Temporadas" },
  ];

  return (
    <div style={{ minHeight: "100vh", background: "#141312", backgroundImage: "repeating-linear-gradient(-45deg, rgba(255,255,255,0.012) 0px, rgba(255,255,255,0.012) 1px, transparent 1px, transparent 14px)", fontFamily: "'Inter', sans-serif" }}>
      <header style={{ borderBottom: "1px solid #2C2B27", position: "sticky", top: 0, background: "rgba(20,19,18,0.92)", backdropFilter: "blur(6px)", zIndex: 20 }}>
        <div style={{ maxWidth: 980, margin: "0 auto", padding: "14px 20px", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <Logo />
          <nav className="desktop-nav" style={{ display: "flex", gap: 4 }}>
            {TABS.map((t) => (
              <button key={t.id} onClick={() => setTab(t.id)} className="navbtn" style={{ fontFamily: "'Oswald', sans-serif", fontSize: 13.5, fontWeight: 500, letterSpacing: 0.5, padding: "9px 14px", borderRadius: 7, border: "none", cursor: "pointer", background: tab === t.id ? "#FFC629" : "transparent", color: tab === t.id ? "#141414" : "#B9B6AC" }}>{t.label}</button>
            ))}
          </nav>
          <button className="mobile-toggle" onClick={() => setMenuOpen((v) => !v)} style={{ background: "none", border: "none", cursor: "pointer", display: "none" }}>
            {menuOpen ? <X color="#F5F3EE" /> : <Menu color="#F5F3EE" />}
          </button>
        </div>
        {menuOpen && (
          <div style={{ borderTop: "1px solid #2C2B27", padding: "10px 20px", display: "flex", flexDirection: "column", gap: 4 }}>
            {TABS.map((t) => (
              <button key={t.id} onClick={() => { setTab(t.id); setMenuOpen(false); }} style={{ fontFamily: "'Oswald', sans-serif", fontSize: 14, textAlign: "left", padding: "10px 12px", borderRadius: 7, border: "none", cursor: "pointer", background: tab === t.id ? "#FFC629" : "transparent", color: tab === t.id ? "#141414" : "#B9B6AC" }}>{t.label}</button>
            ))}
          </div>
        )}
      </header>

      <main style={{ maxWidth: 980, margin: "0 auto", padding: "28px 20px 60px" }}>
        {tab === "inicio" && (
          <div>
            <SectionTitle eyebrow="Estatus en vivo" title="¿Puedo circular ahora mismo?" />
            <SignalCard status={status} />
            <div style={{ marginTop: 28 }}>
              <SectionTitle eyebrow="Cómo usar esta app" title="Guía rápida para tu jornada" />
              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(210px, 1fr))", gap: 12 }}>
                {[
                  { Icon: MapPin, t: "Ciudades", d: "Consulta horarios de restricción por zona metropolitana antes de entrar a la ciudad." },
                  { Icon: ShieldAlert, t: "Carreteras", d: "Identifica si tu tramo federal es de circulación libre o requiere carro piloto." },
                  { Icon: Calendar, t: "Temporadas", d: "Revisa restricciones especiales en Semana Santa, puentes y días festivos." },
                ].map((it) => (
                  <div key={it.t} style={{ background: "#1B1B1A", border: "1px solid #2C2B27", borderRadius: 10, padding: 16 }}>
                    <it.Icon size={20} color="#FFC629" />
                    <div style={{ fontFamily: "'Oswald', sans-serif", fontSize: 15, fontWeight: 600, color: "#F5F3EE", marginTop: 10 }}>{it.t}</div>
                    <div style={{ fontFamily: "'Inter', sans-serif", fontSize: 13, color: "#9C998E", marginTop: 5, lineHeight: 1.5 }}>{it.d}</div>
                  </div>
                ))}
              </div>
                    
            </div>
            <DisclaimerBox />
          </di
                    {
  "name": "Ruta Libre — Carga Pesada MX",
  "short_name": "Ruta Libre",
  "description": "Horarios de circulación y rutas de referencia para camiones de carga pesada en México.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#141312",
  "theme_color": "#141312",
  "lang": "es-MX",
  "icons": [
    {
      "src": "data:image/svg+xml;base64,",
      "sizes": "192x192 512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ]
                  }
const CACHE_NAME = "ruta-libre-v1";
const ASSETS = [
  "./",
  "./index.html",
  "./manifest.json",
];

self.addEventListener("install", (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) => cache.addAll(ASSETS))
  );
  self.skipWaiting();
});

self.addEventListener("activate", (event) => {
  event.waitUntil(
    caches.keys().then((keys) =>
      Promise.all(keys.filter((k) => k !== CACHE_NAME).map((k) => caches.delete(k)))
    )
  );
  self.clients.claim();
});

self.addEventListener("fetch", (event) => {
  const url = new URL(event.request.url);
  const isOwnAsset = url.origin === self.location.origin;

  if (isOwnAsset) {
    event.respondWith(
      caches.match(event.request).then(
        (cached) =>
          cached ||
          fetch(event.request).then((res) => {
            const resClone = res.clone();
            caches.open(CACHE_NAME).then((cache) => cache.put(event.request, resClone));
            return res;
          })
      )
    );
  } else {
    event.respondWith(
      fetch(event.request).catch(() => caches.match(event.request))
    );
  }
});
