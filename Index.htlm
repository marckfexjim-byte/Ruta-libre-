<!DOCTYPE html>
<html lang="es-MX">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Ruta Libre — Carga Pesada MX</title>
<meta name="description" content="Horarios de circulación y rutas de referencia para camiones de carga pesada en México." />
<link rel="manifest" href="manifest.json" />
<meta name="theme-color" content="#141312" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Ruta Libre" />
<meta name="mobile-web-app-capable" content="yes" />
<link rel="icon" href="data:image/svg+xml;base64," />
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #141312; }
  body { font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif; color: #F5F3EE; -webkit-tap-highlight-color: transparent; }
  a { color: inherit; }
  ::selection { background: #FFC629; color: #141414; }
  header { border-bottom: 1px solid #2C2B27; position: sticky; top: 0; background: rgba(20,19,18,0.95); z-index: 20; }
  .header-inner { max-width: 980px; margin: 0 auto; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-badge { width: 40px; height: 40px; background: #FFC629; border-radius: 6px; display:flex; align-items:center; justify-content:center; transform: rotate(-2deg); box-shadow: 2px 2px 0 #141414; font-weight: 900; color:#141414; font-size:18px; }
  .logo-text-main { font-size: 19px; font-weight: 700; letter-spacing: 0.5px; }
  .logo-text-sub { font-size: 10.5px; font-weight: 600; color: #0B6E4F; letter-spacing: 3px; }
  nav.desktop-nav { display: flex; gap: 4px; }
  nav.desktop-nav button, .mobile-menu button { font-size: 13.5px; font-weight: 600; letter-spacing: 0.5px; padding: 9px 14px; border-radius: 7px; border: none; cursor: pointer; background: transparent; color: #B9B6AC; }
  nav.desktop-nav button.active, .mobile-menu button.active { background: #FFC629; color: #141414; }
  .mobile-toggle { display: none; background: none; border: none; cursor: pointer; color: #F5F3EE; font-size: 22px; }
  .mobile-menu { display: none; flex-direction: column; gap: 4px; border-top: 1px solid #2C2B27; padding: 10px 20px; }
  .mobile-menu button { text-align: left; }
  @media (max-width: 720px) { nav.desktop-nav { display: none; } .mobile-toggle { display: block; } }
  main { max-width: 980px; margin: 0 auto; padding: 28px 20px 60px; }
  .eyebrow { font-size: 11px; letter-spacing: 3px; color: #FFC629; font-weight: 700; }
  .title { font-size: 22px; font-weight: 700; margin-top: 2px; }
  .section-title { margin-bottom: 16px; }
  .signal-card { position: relative; border-radius: 12px; padding: 22px 20px; }
  .signal-good { border: 3px solid #0B6E4F; background: linear-gradient(135deg, #0F2E22 0%, #12241D 100%); }
  .signal-bad { border: 3px solid #C1272D; background: linear-gradient(135deg, #3A1216 0%, #241012 100%); }
  .signal-label { font-size: 12px; letter-spacing: 2.5px; font-weight: 700; }
  .signal-good .signal-label { color: #6FD9AE; }
  .signal-bad .signal-label { color: #FF8A8F; }
  .signal-text { font-size: 24px; font-weight: 700; margin-top: 6px; }
  .signal-sub { font-size: 13.5px; color: #B9B6AC; margin-top: 8px; line-height: 1.5; }
  .grid3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 12px; }
  .info-tile { background: #1B1B1A; border: 1px solid #2C2B27; border-radius: 10px; padding: 16px; }
  .info-tile .t { font-size: 15px; font-weight: 700; margin-top: 10px; }
  .info-tile .d { font-size: 13px; color: #9C998E; margin-top: 5px; line-height: 1.5; }
  .city-card { background: #1B1B1A; border: 1px solid #2C2B27; border-radius: 10px; padding: 16px 18px; cursor: pointer; margin-bottom: 10px; }
  .city-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .city-name { font-size: 16px; font-weight: 700; }
  .city-zone { font-size: 13px; color: #9C998E; margin-top: 3px; }
  .badge { font-size: 10.5px; font-weight: 700; padding: 4px 9px; border-radius: 20px; white-space: nowrap; }
  .badge-alta { background: #3A1216; color: #FF8A8F; border: 1px solid #C1272D55; }
  .badge-media { background: #3A2E0E; color: #FFD666; border: 1px solid #FFC62955; }
  .badge-baja { background: #0F2E22; color: #6FD9AE; border: 1px solid #0B6E4F55; }
  .chev { transition: transform .15s ease; color: #6B6960; }
  .city-detail { margin-top: 14px; padding-top: 14px; border-top: 1px dashed #333230; display: none; }
  .city-card.open .city-detail { display: block; }
  .city-card.open .chev { transform: rotate(90deg); }
  .info-row { margin-bottom: 9px; }
  .info-row .label { font-size: 10.5px; letter-spacing: 1.5px; color: #0B6E4F; font-weight: 700; }
  .info-row .value { font-size: 13.5px; color: #D8D5CB; line-height: 1.5; margin-top: 2px; }
  .fuente { font-size: 11.5px; color: #6B6960; margin-top: 10px; }
  .kam-card { background: #1B1B1A; border-radius: 10px; padding: 18px; margin-bottom: 12px; border-left: 4px solid; }
  .kam-title { font-size: 17px; font-weight: 700; }
  .kam-desc { font-size: 13px; color: #9C998E; margin-top: 4px; }
  .kam-time { display: flex; align-items: center; gap: 7px; margin-top: 12px; font-size: 13.5px; color: #D8D5CB; }
  .warn-box { margin-top: 20px; background: #241C0C; border: 1px solid #FFC62944; border-radius: 10px; padding: 16px; display: flex; gap: 12px; font-size: 13px; color: #E8D9A8; line-height: 1.6; }
  .disclaimer { margin-top: 24px; background: #1B1B1A; border: 1px dashed #3A3833; border-radius: 10px; padding: 14px; display: flex; gap: 10px; font-size: 12px; color: #8B8880; line-height: 1.6; }
  .temp-card { background: #1B1B1A; border: 1px solid #2C2B27; border-radius: 10px; padding: 18px; margin-bottom: 12px; }
  .temp-name { font-size: 16px; font-weight: 700; }
  .temp-detail { font-size: 13.5px; color: #D8D5CB; margin-top: 8px; line-height: 1.6; }
  .temp-action { font-size: 12.5px; color: #FFD666; margin-top: 10px; padding-top: 10px; border-top: 1px dashed #333230; }
  .source-link { display: flex; align-items: center; justify-content: space-between; background: #1B1B1A; border: 1px solid #2C2B27; border-radius: 8px; padding: 12px 16px; text-decoration: none; margin-bottom: 8px; font-size: 13.5px; color: #D8D5CB; }
  footer { border-top: 1px solid #2C2B27; padding: 20px; text-align: center; font-size: 12px; color: #6B6960; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
</style>
</head>
<body>
<header>
  <div class="header-inner">
    <div class="logo">
      <div class="logo-badge">RL</div>
      <div>
        <div class="logo-text-main">RUTA LIBRE</div>
        <div class="logo-text-sub">CARGA PESADA MX</div>
      </div>
    </div>
    <nav class="desktop-nav" id="desktopNav"></nav>
    <button class="mobile-toggle" id="mobileToggle">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu"></div>
</header>
<main>
  <div id="tab-inicio" class="tab-panel">
    <div class="section-title"><div class="eyebrow">ESTATUS EN VIVO</div><div class="title">¿Puedo circular ahora mismo?</div></div>
    <div id="signalCard"></div>
    <div style="margin-top:28px;">
      <div class="section-title"><div class="eyebrow">CÓMO USAR ESTA APP</div><div class="title">Guía rápida para tu jornada</div></div>
      <div class="grid3">
        <div class="info-tile"><div class="t">Ciudades</div><div class="d">Consulta horarios de restricción por zona metropolitana antes de entrar a la ciudad.</div></div>
        <div class="info-tile"><div class="t">Carreteras</div><div class="d">Identifica si tu tramo federal es de circulación libre o requiere carro piloto.</div></div>
        <div class="info-tile"><div class="t">Temporadas</div><div class="d">Revisa restricciones especiales en Semana Santa, puentes y días festivos.</div></div>
      </div>
    </div>
    <div class="disclaimer">⚠ Los horarios y zonas pueden cambiar por decreto o contingencia ambiental. Esta guía resume disposiciones publicadas por las autoridades; confirma siempre en la fuente oficial antes de iniciar tu ruta.</div>
  </div>
  <div id="tab-ciudades" class="tab-panel">
    <div class="section-title"><div class="eyebrow">ZONAS URBANAS</div><div class="title">Restricciones por ciudad</div></div>
    <div id="ciudadesList"></div>
    <div class="disclaimer">⚠ Los horarios y zonas pueden cambiar por decreto o contingencia ambiental. Confirma siempre en la fuente oficial antes de iniciar tu ruta.</div>
  </div>
  <div id="tab-carreteras" class="tab-panel">
    <div class="section-title"><div class="eyebrow">RED FEDERAL</div><div class="title">Tipos de camino y horarios</div></div>
    <div id="caminosList"></div>
    <div class="warn-box">⚠ La clasificación (ET4, A2, etc.) la define la SICT según el proyecto geométrico de cada tramo. Verifícala en el señalamiento vertical de la carretera o en el portal de la SICT antes de planear tu ruta.</div>
    <div class="disclaimer">⚠ Los horarios y zonas pueden cambiar por decreto o contingencia ambiental. Confirma siempre en la fuente oficial antes de iniciar tu ruta.</div>
  </div>
  <div id="tab-temporadas" class="tab-panel">
    <div class="section-title"><div class="eyebrow">FECHAS ESPECIALES</div><div class="title">Restricciones por temporada</div></div>
    <div id="temporadasList"></div>
    <div class="disclaimer">⚠ Los horarios y zonas pueden cambiar por decreto o contingencia ambiental. Confirma siempre en la fuente oficial antes de iniciar tu ruta.</div>
  </div>
  <div style="margin-top:30px;">
    <div class="section-title"><div class="eyebrow">VERIFICA SIEMPRE</div><div class="title">Fuentes oficiales</div></div>
    <div id="fuentesList"></div>
  </div>
</main>
<footer>Guía de referencia — no sustituye avisos oficiales vigentes de SICT, SEMOVI o gobiernos estatales.</footer>
<script>
var CIUDADES = [
  { id: "cdmx-centro", ciudad: "Ciudad de México", zona: "Centro Histórico (Perímetro A)", peso: "3.8 – 20 toneladas", regla: "Prohibida la circulación y maniobras de carga de 07:00 a 20:00 h, todos los días.", libre: "20:00 h – 07:00 h", excepciones: "Vehículos de emergencia, mudanzas con permiso, servicios funerarios y transporte de residuos peligrosos autorizado.", fuente: "SEMOVI CDMX", nivel: "alta" },
  { id: "cdmx-periferico", ciudad: "Ciudad de México", zona: "Periférico y Circuito Interior (carriles centrales)", peso: "Más de 3.8 toneladas", regla: "Restringido en carriles centrales del Periférico según el Reglamento de Tránsito, Art. 26. Los carriles laterales suelen permitir carga ligera.", libre: "Consulta vialidad específica", excepciones: "Verifica el tramo exacto: la restricción varía entre norte, sur, oriente y poniente.", fuente: "Reglamento de Tránsito CDMX", nivel: "media" },
  { id: "cdmx-hoy-no-circula", ciudad: "Ciudad de México y Zona Metropolitana", zona: "Hoy No Circula (aplica también a carga sin holograma 00/0)", peso: "Todos los pesos, según holograma de verificación", regla: "Rotación diaria por terminación de placa y holograma. Contingencias ambientales añaden restricciones extra (Fase 1 / Fase 2).", libre: "Días y horas fuera de tu rotación asignada", excepciones: "Diésel y gas LP con normas propias; unidades 00 exentas salvo contingencia.", fuente: "SEDEMA / Programa de Verificación Vehicular", nivel: "media" },
  { id: "gdl", ciudad: "Guadalajara (ZMG)", zona: "Centro y Anillo Periférico", peso: "Más de 3.5 toneladas", regla: "Circulación de carga restringida en el primer cuadro en horario diurno; carga y descarga solo en horario nocturno autorizado.", libre: "Horario nocturno (confirmar con Movilidad Jalisco)", excepciones: "Reparto local con permiso municipal.", fuente: "Movilidad Jalisco", nivel: "media" },
  { id: "mty", ciudad: "Monterrey (AMM)", zona: "Centro y vialidades primarias", peso: "Más de 8.5 toneladas", regla: "Restricción en horas pico (07:00–09:30 y 18:00–20:30) sobre ejes viales primarios.", libre: "Fuera de horas pico", excepciones: "Carga urgente con permiso de la Agencia para la Racionalización y Modernización del Transporte Público (AC Transporte).", fuente: "Gobierno de Nuevo León", nivel: "baja" },
  { id: "puebla", ciudad: "Puebla", zona: "Centro Histórico", peso: "Más de 3.5 toneladas", regla: "Prohibida circulación diurna en el Centro Histórico; carga y descarga solo de 22:00 a 06:00 h.", libre: "22:00 h – 06:00 h", excepciones: "Servicios esenciales con permiso.", fuente: "Ayuntamiento de Puebla", nivel: "media" }
];
var CAMINOS_FEDERALES = [
  { tipo: "ET4 / A4 / B4", desc: "Carreteras de altas especificaciones (4 carriles, cuota o libres amplias)", circulacion: "Libre las 24 horas, todos los días", color: "#0B6E4F" },
  { tipo: "ET2 / A2 / B2 / C / D", desc: "Carreteras de 2 carriles o especificación menor", circulacion: "Diurno 06:00–18:30 h. Nocturno 00:00–06:00 y 18:30–23:59 h, condicionado a usar carro piloto delantero y trasero", color: "#FFC629" }
];
var TEMPORADAS = [
  { nombre: "Semana Santa", detalle: "La Dirección General de Autotransporte Federal (DGAF) emite un aviso anual restringiendo carga pesada en fechas de mayor afluencia. Grúas industriales y transporte de maquinaria pesada suelen suspender circulación por completo en los días pico.", accion: "Revisa el aviso oficial de la DGAF/SCT cada año antes de Semana Santa — las fechas exactas cambian." },
  { nombre: "Puentes y días festivos", detalle: "Muchos estados aplican restricciones similares en Navidad, Año Nuevo y puentes largos, sobre todo en accesos a zonas turísticas y metropolitanas.", accion: "Consulta el calendario de la SICT y el gobierno estatal del tramo antes de salir." }
];
var FUENTES_OFICIALES = [
  { nombre: "SICT — Secretaría de Infraestructura, Comunicaciones y Transportes", url: "https://www.gob.mx/sict" },
  { nombre: "SEMOVI Ciudad de México", url: "https://semovi.cdmx.gob.mx" },
  { nombre: "Gaceta Oficial de la Ciudad de México", url: "https://data.consejeria.cdmx.gob.mx/index.php/gaceta" },
  { nombre: "Guardia Nacional — Carreteras (estado de vialidades)", url: "https://www.gob.mx/guardianacional" }
];
var TABS = [
  { id: "inicio", label: "Inicio" },
  { id: "ciudades", label: "Ciudades" },
  { id: "carreteras", label: "Carreteras" },
  { id: "temporadas", label: "Temporadas" }
];
function el(tag, attrs, html) {
  var e = document.createElement(tag);
  if (attrs) for (var k in attrs) e.setAttribute(k, attrs[k]);
  if (html !== undefined) e.innerHTML = html;
  return e;
}
function renderNav() {
  var desktopNav = document.getElementById("desktopNav");
  var mobileMenu = document.getElementById("mobileMenu");
  desktopNav.innerHTML = "";
  mobileMenu.innerHTML = "";
  TABS.forEach(function (t) {
    var b1 = el("button", {}, t.label);
    b1.onclick = function () { setTab(t.id); };
    b1.dataset.tab = t.id;
    desktopNav.appendChild(b1);
    var b2 = el("button", {}, t.label);
    b2.onclick = function () { setTab(t.id); mobileMenu.style.display = "none"; };
    b2.dataset.tab = t.id;
    mobileMenu.appendChild(b2);
  });
}
function setTab(id) {
  document.querySelectorAll(".tab-panel").forEach(function (p) { p.classList.remove("active"); });
  document.getElementById("tab-" + id).classList.add("active");
  document.querySelectorAll("[data-tab]").forEach(function (b) {
    b.classList.toggle("active", b.dataset.tab === id);
  });
}
document.getElementById("mobileToggle").onclick = function () {
  var m = document.getElementById("mobileMenu");
  m.style.display = (m.style.display === "flex") ? "none" : "flex";
};
function renderSignal() {
  var now = new Date();
  var hora = now.getHours();
  var centroActivo = !(hora >= 7 && hora < 20);
  var horaTxt = now.toLocaleTimeString("es-MX", { hour: "2-digit", minute: "2-digit" });
  var card = document.getElementById("signalCard");
  card.className = "signal-card " + (centroActivo ? "signal-good" : "signal-bad");
  if (centroActivo) {
    card.innerHTML = '<div class="signal-label">CIRCULACIÓN PERMITIDA</div>' +
      '<div class="signal-text">Centro Histórico CDMX — vía libre</div>' +
      '<div class="signal-sub">Son las ' + horaTxt + '. El horario libre para carga (3.8–20 t) es de 20:00 a 07:00 h.</div>';
  } else {
    var faltan = 20 - hora;
    if (faltan <= 0) faltan += 24;
    card.innerHTML = '<div class="signal-label">CIRCULACIÓN RESTRINGIDA</div>' +
      '<div class="signal-text">Centro Histórico CDMX — restringido</div>' +
      '<div class="signal-sub">Son las ' + horaTxt + '. Se libera a las 20:00 h (en ' + faltan + ' h aprox.).</div>';
  }
}
function labelForNivel(n) {
  if (n === "alta") return "Restricción estricta";
  if (n === "media") return "Restricción parcial";
  return "Restricción leve";
}
function renderCiudades() {
  var list = document.getElementById("ciudadesList");
  list.innerHTML = "";
  CIUDADES.forEach(function (c) {
    var card = el("div", { class: "city-card" });
    card.innerHTML =
      '<div class="city-top">' +
        '<div><div class="city-name">' + c.ciudad + '</div><div class="city-zone">' + c.zona + '</div></div>' +
        '<div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">' +
          '<span class="badge badge-' + c.nivel + '">' + labelForNivel(c.nivel) + '</span>' +
          '<span class="chev">›</span>' +
        '</div>' +
      '</div>' +
      '<div class="city-detail">' +
        '<div class="info-row"><div class="label">PESO QUE APLICA</div><div class="value">' + c.peso + '</div></div>' +
        '<div class="info-row"><div class="label">RESTRICCIÓN</div><div class="value">' + c.regla + '</div></div>' +
        '<div class="info-row"><div class="label">CIRCULACIÓN LIBRE</div><div class="value">' + c.libre + '</div></div>' +
        '<div class="info-row"><div class="label">EXCEPCIONES</div><div class="value">' + c.excepciones + '</div></div>' +
        '<div class="fuente">Fuente: ' + c.fuente + '</div>' +
      '</div>';
    card.onclick = function () { card.classList.toggle("open"); };
    list.appendChild(card);
  });
  if (list.firstChild) list.firstChild.classList.add("open");
}
function renderCaminos() {
  var list = document.getElementById("caminosList");
  list.innerHTML = "";
  CAMINOS_FEDERALES.forEach(function (k) {
    var card = el("div", { class: "kam-card", style: "border-left-color:" + k.color + ";background:#1B1B1A;" });
    card.innerHTML =
      '<div class="kam-title">' + k.tipo + '</div>' +
      '<div class="kam-desc">' + k.desc + '</div>' +
      '<div class="kam-time">🕐 ' + k.circulacion + '</div>';
    list.appendChild(card);
  });
}
function renderTemporadas() {
  var list = document.getElementById("temporadasList");
  list.innerHTML = "";
  TEMPORADAS.forEach(function (t) {
    var card = el("div", { class: "temp-card" });
    card.innerHTML =
      '<div class="temp-name">' + t.nombre + '</div>' +
      '<div class="temp-detail">' + t.detalle + '</div>' +
      '<div class="temp-action">→ ' + t.accion + '</div>
